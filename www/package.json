{
  "author": "lijay <lijay@ape.contact>",
  "name": "gorilla-physics-ui",
  "version": "0.0.1",
  "description": "UI for gorilla-physics",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "scripts": {
    "build": "rimraf dist pkg && rspack",
    "start": "rimraf dist pkg && rspack serve --open --node-env development",
    "prod": "rimraf dist pkg && rspack serve --open --node-env production",
    "build:gpu": "FEATURE_GPU=1 npm run build",
    "start:gpu": "FEATURE_GPU=1 npm run start",
    "prod:gpu": "FEATURE_GPU=1 npm run prod",
    "build:types": "tsc --emitDeclarationOnly",
    "build:lib": "tsc --project tsconfig.json --watch"
  },
  "dependencies": {
    "gorilla-physics": "file:../pkg",
    "three": "^0.152.0"
  },
  "devDependencies": {
    "@rspack/cli": "^2.0.1",
    "@rspack/core": "^2.0.1",
    "@rspack/dev-server": "^2.0.1",
    "@types/three": "^0.144.0",
    "@wasm-tool/wasm-pack-plugin": "^1.1.0",
    "rimraf": "^3.0.2",
    "ts-loader": "^9.4.1",
    "typescript": "^4.9.5"
  }
}
